{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roadmap-kit.local/schemas/roadmap.schema.json",
  "title": "Active Roadmap Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_kind",
    "schema_version",
    "id",
    "title",
    "status",
    "updated_at",
    "scope",
    "source_of_truth",
    "mission",
    "baseline",
    "rules",
    "archive_policy",
    "execution_order",
    "current_focus",
    "phases"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_kind": {
      "const": "roadmap"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "#/$defs/root_status"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "source_of_truth": {
      "type": "boolean"
    },
    "mission": {
      "type": "string",
      "minLength": 1
    },
    "baseline": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/baseline_item"
      },
      "minItems": 1
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      },
      "minItems": 1
    },
    "archive_policy": {
      "$ref": "#/$defs/archive_policy"
    },
    "execution_order": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "current_focus": {
      "$ref": "#/$defs/current_focus"
    },
    "phases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/phase"
      },
      "minItems": 1
    }
  },
  "$defs": {
    "root_status": {
      "type": "string",
      "enum": [
        "active",
        "archived"
      ]
    },
    "item_status": {
      "type": "string",
      "enum": [
        "planned",
        "in_progress",
        "blocked",
        "done",
        "active",
        "archived"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "p0",
        "p1",
        "p2",
        "p3"
      ]
    },
    "task_kind": {
      "type": "string",
      "enum": [
        "contract",
        "implementation",
        "validation",
        "architecture",
        "automation",
        "governance",
        "research"
      ]
    },
    "baseline_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "const": "done"
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "text",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "const": "active"
        }
      }
    },
    "archive_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_document",
        "historical_directory",
        "historical_format",
        "snapshots"
      ],
      "properties": {
        "active_document": {
          "const": "ROADMAP.json"
        },
        "historical_directory": {
          "type": "string",
          "minLength": 1
        },
        "historical_format": {
          "const": "markdown"
        },
        "snapshots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/archive_snapshot"
          }
        }
      }
    },
    "archive_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "kind",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "const": "archived"
        }
      }
    },
    "current_focus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase_id",
        "task_ids",
        "why"
      ],
      "properties": {
        "phase_id": {
          "type": "string",
          "minLength": 1
        },
        "task_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "why": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status",
        "priority",
        "goal",
        "tasks",
        "exit_criteria"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/item_status"
        },
        "priority": {
          "$ref": "#/$defs/priority"
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/task"
          },
          "minItems": 1
        },
        "exit_criteria": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status",
        "priority",
        "kind",
        "summary",
        "depends_on",
        "acceptance_criteria",
        "evidence_required",
        "files"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/item_status"
        },
        "priority": {
          "$ref": "#/$defs/priority"
        },
        "kind": {
          "$ref": "#/$defs/task_kind"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "evidence_required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    }
  }
}
