# Maintainer: Gabriel Capilla <gabriel@example.com>

pkgname=parun
pkgver=0.6.0
pkgrel=1
pkgdesc="Terminal UI for pacman, AUR, and nimble"
arch=('x86_64')
url="https://github.com/gabrielcapilla/parun"
license=('MIT')
depends=('pacman' 'nimble' 'openssl')
makedepends=('nim')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('REPLACE_WITH_TAG_TARBALL_SHA256')

build() {
  cd "$srcdir/$pkgname-$pkgver"
  nimble release -y
}

check() {
  cd "$srcdir/$pkgname-$pkgver"
  ./parun --version
}

package() {
  cd "$srcdir/$pkgname-$pkgver"
  install -Dm755 parun "$pkgdir/usr/bin/parun"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
