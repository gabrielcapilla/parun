# Maintainer: Gabriel Capilla
pkgname=parun
pkgver=0.7.0
pkgrel=1
pkgdesc='Terminal UI for pacman, AUR and nimble'
arch=('x86_64')
url='https://github.com/gabrielcapilla/parun'
license=('AGPL-3.0-or-later')
depends=('glibc' 'openssl' 'pacman')
makedepends=('gcc' 'nim' 'nimble')
optdepends=(
  'paru: AUR backend'
  'yay: fallback AUR backend'
  'nimble: Nim package source support'
)
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${pkgname}-${pkgver}"

  nimble build \
    -d:release \
    --passC:"${CPPFLAGS} ${CFLAGS}" \
    --passL:"${LDFLAGS}"
}

package() {
  cd "${pkgname}-${pkgver}"

  install -Dm755 parun "${pkgdir}/usr/bin/parun"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
